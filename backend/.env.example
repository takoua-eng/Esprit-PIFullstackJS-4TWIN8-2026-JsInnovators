PORT=3000

# Atlas: prefer mongodb+srv from Atlas UI. If you see querySrv ECONNREFUSED, try optional DNS below
# or use Atlas "standard connection string" (mongodb://host1:27017,host2:27017,...) instead of +srv.
MONGODB_URI=mongodb://127.0.0.1:27017/medifollow
MONGODB_DB_NAME=medifollow

# Optional: if SRV DNS fails on your network, uncomment (uses Google + Cloudflare DNS for Node only)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

PATIENT_ROLE_ID=
