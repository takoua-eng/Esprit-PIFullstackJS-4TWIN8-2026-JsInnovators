PORT=3000

# Copy this file to `.env` in the same folder (Nest loads `.env`, NOT `.env.example`).
# Do not put a space before the key name — ` MONGODB_URI` is invalid and forces fallback to localhost.

# Atlas: paste from Atlas → Connect → Drivers (replace USER and PASSWORD)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/medifollow

# Must match the database name in the Compass sidebar (e.g. test, medifollow, sample_mflix)
MONGODB_DB_NAME=test

# Optional: if mongodb+srv fails with querySrv ECONNREFUSED on Windows:
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

PATIENT_ROLE_ID=

GROQ_API_KEY=

# After start, check: GET http://localhost:3000/alerts/data-summary
# `database` and counts must match what you see in Compass.
